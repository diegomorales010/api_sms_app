<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_ip_address"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="IP actual: calculando..."
        android:textSize="16sp"
        android:layout_marginTop="24dp" />

    <Button
        android:id="@+id/btn_start"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Iniciar API SMS" />

    <Button
        android:id="@+id/btn_stop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Detener API"
        android:layout_marginTop="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Prueba: POST http://tu-ip-local:8080/send con body {'phone': '1234567890', 'message': 'Hola desde Android!'}"
        android:layout_marginTop="48dp"
        android:textAlignment="center" />

    <Button
        android:id="@+id/btn_view_history"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ver historial de peticiones"
        android:layout_marginTop="24dp" />
        
    <Button
    android:id="@+id/btn_config_ips"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Configurar IPs permitidas"
    android:layout_marginTop="16dp"/>

</LinearLayout>